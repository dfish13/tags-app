# Postgres credentials (used by docker-compose)
POSTGRES_USER=tags
POSTGRES_PASSWORD=changeme
POSTGRES_DB=tags

# Connection string for local (non-Docker) dev, e.g. drizzle-kit / npm run dev
DATABASE_URL=postgres://tags:changeme@localhost:5432/tags

# Comma-separated admin email allowlist, seeded into the `admins` table on
# boot. These emails get write access (must also be allowed in Cloudflare
# Access). Leave blank to seed no admins.
ADMIN_EMAILS=admin@example.com

# League name shown in the app header and page title. Each deployment sets its
# own — the same code runs for any league.
LEAGUE_NAME=Tags League

# Optional theme overrides. Leave any blank to keep the app's default look.
# Colors are CSS hex; the pressed-button shade is derived from THEME_PRIMARY.
# THEME_FONT is any CSS font-family value (use a system/generic family, or load
# a web font yourself). Examples:
#   THEME_PRIMARY=#1f3a5f
#   THEME_ACCENT=#ffb703
#   THEME_SECONDARY=#457b9d
#   THEME_BG=#f2f4f7
#   THEME_FONT=Georgia, serif
THEME_PRIMARY=
THEME_ACCENT=
THEME_SECONDARY=
THEME_BG=
THEME_FONT=
